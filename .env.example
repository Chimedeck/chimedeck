# Chimedeck — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed.

# ──────────────────────────────────────────
# Required
# ──────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://chimedeck:chimedeck@localhost:5432/chimedeck

# RS256 JWT keys (PEM format, base64-encoded or raw)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# S3 / file storage
# When FLAG_USE_LOCAL_STORAGE=true (default in dev), these are auto-set to LocalStack.
# Set FLAG_USE_LOCAL_STORAGE=false and fill in real AWS credentials for production.
S3_BUCKET=chimedeck

# Trello seed data — optional presigned S3 URL to download all_trello_cards.json
# when the file is not already present at db/all_trello_cards.json.
# Example: https://your-bucket.s3.ap-southeast-1.amazonaws.com/all_trello_cards.json?X-Amz-...
SEED_FILE_URL=
S3_REGION=us-east-1
# Production AWS S3 endpoint (leave blank in local dev):
S3_ENDPOINT=
# S3-specific credentials — set these to target LocalStack while keeping real AWS
# credentials in AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY for SES.
# When unset, the S3 client falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
S3_AWS_ACCESS_KEY_ID=
S3_AWS_SECRET_ACCESS_KEY=
# Global AWS credentials — used by SES and as fallback for S3 when S3_AWS_* are unset.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# HTTP server port
APP_PORT=3000

# ──────────────────────────────────────────
# Optional — Redis (pub/sub, rate limiting, presence)
# ──────────────────────────────────────────
# Leave blank or omit to run without Redis (FLAG_USE_REDIS=false mode).
# Enable Redis: docker compose --profile redis up
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────

# Set FLAG_USE_REDIS=false to use in-process EventEmitter + node-cache fallbacks.
FLAG_USE_REDIS=false

# Storage: true = LocalStack (local dev), false = AWS S3 (production)
FLAG_USE_LOCAL_STORAGE=true

# Disable virus scanning in local dev
FLAG_VIRUS_SCAN_ENABLED=false

# OAuth providers (true/false)
FLAG_OAUTH_GOOGLE_ENABLED=true
FLAG_OAUTH_GITHUB_ENABLED=true

# Email verification (Sprint 23)
FLAG_EMAIL_VERIFICATION_ENABLED=false
FLAG_SES_ENABLED=false

# AWS SES — required when FLAG_SES_ENABLED=true
SES_REGION=us-east-1
SES_FROM_ADDRESS=noreply@example.com
# SES uses the global AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (see S3 section above).
# Do NOT use S3_AWS_ACCESS_KEY_ID / S3_AWS_SECRET_ACCESS_KEY for SES — those are for LocalStack only.

# Feature flag provider — set to "flagsmith", "featbit", or leave empty for local-only
FEATURE_FLAGS_PROVIDER=

# Path to a JSON file with flag overrides, e.g. /config/flags.json
# JSON format: { "USE_REDIS": false, "VIRUS_SCAN_ENABLED": false }
FEATURE_FLAGS_JSON_PATH=

# === Docker / Build ===
APP_PORT=3000
NODE_ENV=development

# === Docker production image ===
DOCKER_IMAGE=chimedeck-app
IMAGE_TAG=latest


# Platform admin emails — comma-separated list of emails that can manage the plugin registry
PLATFORM_ADMIN_EMAILS=

# Client-side platform admin emails (exposed to Vite — comma-separated)
VITE_PLATFORM_ADMIN_EMAILS=

# Public base URL of this Chimedeck instance — used in the MCP docs page
VITE_APP_URL=https://your-app.example.com

# Email domain allowlist — comma-separated domains permitted to self-register or change email
# e.g. ALLOWED_EMAIL_DOMAINS=journeyh.io,partner.org
ALLOWED_EMAIL_DOMAINS=journeyh.io

# Set to false to disable domain restriction entirely (useful in development)
EMAIL_DOMAIN_RESTRICTION_ENABLED=true

# Admin email domains — comma-separated domains that receive admin-level access
# Intentionally separate from ALLOWED_EMAIL_DOMAINS
ADMIN_EMAIL_DOMAINS=journeyh.io

# Set to "true" to run the Trello import seed (bun run db:seed:trello) on container startup
SEED_TRELLO=false

# === Automation Scheduler ===
# Set to "false" to disable time-based automations (SCHEDULED + DUE_DATE) without
# disabling the rest of the automation system.
AUTOMATION_SCHEDULER_ENABLED=true

# Set to "true" when pg_cron is installed on the DB host (production).
# Set to "false" (default for local dev) to use the Bun Worker fallback — required
# because postgres:16-alpine does not include the pg_cron extension.
# See docs/sprint-64.md §2 for the full pg_cron production setup checklist.
AUTOMATION_USE_PGCRON=false

# ──────────────────────────────────────────
# Sentry — error monitoring (optional)
# ──────────────────────────────────────────

# Server-side Sentry (Node/@sentry/node).
# Set SENTRY_SERVER_ENABLED=true and provide SENTRY_SERVER_DSN to enable.
# Leave blank or set to "false" to run without Sentry.
SENTRY_SERVER_ENABLED=false
SENTRY_SERVER_DSN=

# Client-side Sentry (@sentry/react, Vite-exposed).
# Set VITE_SENTRY_CLIENT_ENABLED=true and provide VITE_SENTRY_CLIENT_DSN to enable.
# Leave blank or set to "false" to run without Sentry.
VITE_SENTRY_CLIENT_ENABLED=false
VITE_SENTRY_CLIENT_DSN=

# Shared deployment context — same values used by both client and server.
# SENTRY_ENV should match the deployment tier, e.g. "production", "staging", "development".
# SENTRY_RELEASE is typically a git SHA or semver tag; leave empty in local dev.
SENTRY_ENV=development
SENTRY_RELEASE=
# Vite-exposed copies of the shared context (read by the client config module):
VITE_SENTRY_ENV=development
VITE_SENTRY_RELEASE=
