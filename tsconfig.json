{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // DOM libs are needed for src/ — harmless for server files with skipLibCheck
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    // bun-types covers server; vite/client covers src — skipLibCheck prevents conflicts
    "types": ["bun-types", "vite/client"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  // Include both src/ and server/ so VS Code resolves ~ aliases in all files
  "include": ["src/**/*", "server/**/*.ts", "vite.config.ts", "tailwind.config.ts"],
  "exclude": ["node_modules", "dist", "sample-project"]
}
