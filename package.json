{
  "name": "agentic-trello-replacement",
  "version": "0.1.0",
  "description": "Collaborative Kanban System — server",
  "module": "server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot server/index.ts",
    "start": "bun server/index.ts",
    "lint": "eslint 'server/**/*.ts'",
    "format": "prettier --write 'server/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:migrate": "knex --knexfile db/knexfile.ts migrate:latest",
    "db:rollback": "knex --knexfile db/knexfile.ts migrate:rollback",
    "db:seed": "bun run db/seeds/run.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "^1.3.10",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
