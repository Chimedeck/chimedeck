{
  "name": "agentic-trello-replacement",
  "version": "0.1.0",
  "description": "Collaborative Kanban System — server",
  "module": "server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot server/index.ts",
    "start": "bun server/index.ts",
    "lint": "eslint 'server/**/*.ts'",
    "format": "prettier --write 'server/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bunx prisma migrate dev",
    "db:migrate:deploy": "bunx prisma migrate deploy",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "^1.3.10",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0"
  }
}
