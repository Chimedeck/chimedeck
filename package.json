{
  "name": "taskinate",
  "version": "0.1.0",
  "description": "taskinate — server",
  "module": "server/index.ts",
  "type": "module",
  "bin": {
    "taskinate": "dist/cli/index.js"
  },
  "files": [
    "dist/cli"
  ],
  "scripts": {
    "build:cli": "bun build cli/index.ts --outdir dist/cli --target node && sed -i '' '1{/^#!/d;}' dist/cli/index.js && printf '#!/usr/bin/env node\\n' | cat - dist/cli/index.js > dist/cli/index.tmp && mv dist/cli/index.tmp dist/cli/index.js && chmod +x dist/cli/index.js",
    "prepublishOnly": "bun run build:cli",
    "dev": "bun run --hot server/index.ts",
    "dev:client": "vite",
    "dev:local": "concurrently \"bun run dev\" \"bun run dev:client\"",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "bun run typecheck",
    "start": "NODE_ENV=production bun run server/index.ts",
    "db:migrate": "bun run node_modules/.bin/knex --knexfile db/knexfile.ts migrate:latest",
    "db:rollback": "bun run node_modules/.bin/knex --knexfile db/knexfile.ts migrate:rollback",
    "db:seed": "bun run db/seeds/run.ts",
    "db:seed:trello": "bun run db/seeds/trello-import.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "docker:dev": "docker compose -f docker-compose.yml up --build",
    "docker:dev:redis": "docker compose -f docker-compose.yml --profile redis up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up",
    "docker:build": "docker build -t taskinate-app:latest .",
    "docker:build:nc": "docker build --no-cache -t taskinate-app:latest .",
    "test:load": "k6 run tests/load/board-load.js && k6 run tests/load/drag-latency.js && k6 run tests/load/ws-broadcast.js",
    "clean": "rm -rf dist .vite node_modules/.cache"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-ses": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@radix-ui/react-avatar": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-tooltip": "^1",
    "@reduxjs/toolkit": "^2.11.2",
    "@tiptap/extension-image": "^3.20.3",
    "@tiptap/extension-mention": "^3.20.4",
    "@tiptap/markdown": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "@types/marked": "^6.0.0",
    "@types/sanitize-html": "^2.16.1",
    "axios": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "idb": "^8.0.3",
    "ioredis": "^5.10.0",
    "jose": "^6.1.3",
    "knex": "^3.1.0",
    "lucide-react": "^0.400",
    "marked": "^17.0.3",
    "minimist": "^1.2.8",
    "node-cache": "^5.1.2",
    "pg": "^8.13.0",
    "react": "^18",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18",
    "react-redux": "^9",
    "react-router-dom": "^6",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2",
    "tippy.js": "^6.3.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/minimist": "^1.2.5",
    "@types/pg": "^8.11.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "bun-types": "^1.3.10",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8",
    "prettier": "^3.0.0",
    "tailwindcss": "^3",
    "typescript": "^5.6.0",
    "vite": "^5"
  }
}
