{
  "name": "agentic-trello-replacement",
  "version": "0.1.0",
  "description": "Collaborative Kanban System — server",
  "module": "server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot server/index.ts",
    "dev:client": "vite",
    "dev:full": "concurrently \"bun run dev\" \"bun run dev:client\"",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "bun run typecheck",
    "start": "NODE_ENV=production bun run server/index.ts",
    "db:migrate": "bun run node_modules/.bin/knex --knexfile db/knexfile.ts migrate:latest",
    "db:rollback": "bun run node_modules/.bin/knex --knexfile db/knexfile.ts migrate:rollback",
    "db:seed": "bun run db/seeds/run.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "docker:dev": "docker compose -f docker-compose.yml up --build",
    "docker:dev:redis": "docker compose -f docker-compose.yml --profile redis up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up",
    "docker:build": "docker build -t kanban-app:latest .",
    "docker:build:nc": "docker build --no-cache -t kanban-app:latest .",
    "test:load": "k6 run tests/load/board-load.js && k6 run tests/load/drag-latency.js && k6 run tests/load/ws-broadcast.js",
    "clean": "rm -rf dist .vite node_modules/.cache"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@radix-ui/react-avatar": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-tooltip": "^1",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "ioredis": "^5.10.0",
    "jose": "^6.1.3",
    "knex": "^3.1.0",
    "lucide-react": "^0.400",
    "node-cache": "^5.1.2",
    "pg": "^8.13.0",
    "react": "^18",
    "react-dom": "^18",
    "react-redux": "^9",
    "react-router-dom": "^6",
    "tailwind-merge": "^2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/pg": "^8.11.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "bun-types": "^1.3.10",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8",
    "prettier": "^3.0.0",
    "tailwindcss": "^3",
    "typescript": "^5.6.0",
    "vite": "^5"
  }
}
