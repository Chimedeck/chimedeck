# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars — STABLE
#
# The stable environment is a pre-production mirror. It runs the same deployment
# mode as production but with slightly reduced capacity. Use it to validate
# infrastructure changes before promoting to production.
#
# Copy this file to terraform.tfvars and fill in all values.
# Do NOT commit terraform.tfvars to source control (it is in .gitignore).
#
# After filling in, initialise and apply:
#   terraform init -backend-config=backend.tf
#   terraform plan
#   terraform apply
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# Core / provider
# ─────────────────────────────────────────────

# Short name used as a prefix for resource names (no spaces or uppercase).
app_name = "myapp"

# Common tags applied to every resource in this environment.
tags = {
  Environment = "stable"
  Project     = "myapp"
  ManagedBy   = "terraform"
}

# ─────────────────────────────────────────────
# Deployment mode
# ─────────────────────────────────────────────

# "single"        — one EC2 instance with an Elastic IP; no ALB, no NAT Gateway.
# "fleet"         — fixed-count instances behind an ALB + NAT Gateway.
# "asg-bluegreen" — two ASGs with a weighted ALB listener for zero-downtime deploys.
# Stable typically mirrors the production deployment_mode to catch regressions early.
deployment_mode = "fleet"

# ─────────────────────────────────────────────
# VPC
# ─────────────────────────────────────────────

# Set to true to create an isolated VPC with public and private subnets.
# Recommended for stable to mirror production networking.
create_vpc = true

# ─────────────────────────────────────────────
# EC2 / compute
# ─────────────────────────────────────────────

# Fleet region configuration.
# The FIRST entry is the PRIMARY region — it hosts S3, RDS, Redis, ECR, and
# the primary ALB. Every other entry gets its own VPC, ALB, and EC2 instances.
# AWS Global Accelerator routes users to the nearest healthy regional ALB.
# No NAT Gateways: instances run in public subnets with auto-assigned public IPs.
# VPC peering is created per additional region purely for RDS/Redis access.
#
# vpc_cidr values must not overlap across regions.
# instance_count is fixed at apply time (not autoscaled).
# acm_certificate_arn must be issued in THAT region (ACM certs are regional).
fleet_regions = [
  {
    region               = "ap-southeast-1"
    instance_count       = 2
    ami_id               = "ami-REPLACE_WITH_STABLE_AMI"
    vpc_cidr             = "10.2.0.0/16"
    azs                  = ["ap-southeast-1a", "ap-southeast-1b"]
    acm_certificate_arn  = "arn:aws:acm:ap-southeast-1:123456789012:certificate/REPLACE"
  }
  # 2nd region example:
  # ,{
  #   region               = "us-east-1"
  #   instance_count       = 1
  #   ami_id               = "ami-REPLACE_WITH_US_EAST_AMI"
  #   vpc_cidr             = "10.3.0.0/16"
  #   azs                  = ["us-east-1a", "us-east-1b"]
  #   acm_certificate_arn  = "arn:aws:acm:us-east-1:123456789012:certificate/REPLACE"
  # }
  # 3rd region example:
  # ,{
  #   region               = "eu-west-1"
  #   instance_count       = 1
  #   ami_id               = "ami-REPLACE_WITH_EU_WEST_AMI"
  #   vpc_cidr             = "10.4.0.0/16"
  #   azs                  = ["eu-west-1a", "eu-west-1b"]
  #   acm_certificate_arn  = "arn:aws:acm:eu-west-1:123456789012:certificate/REPLACE"
  # }
]

# EC2 key pair name shared across ALL fleet regions.
# Import the same public key into every listed region under this name.
# Set to null to launch without SSH access (use SSM Session Manager instead).
fleet_key_pair_name = "myapp-stable-keypair"

# Instance type — medium for stable (balance of cost vs. realistic load testing).
instance_type = "t3.medium"

# IAM instance profile name that grants ECR pull + Secrets Manager read.
iam_instance_profile = "myapp-stable-ec2-profile"

# ─────────────────────────────────────────────
# ECR / image
# ─────────────────────────────────────────────

# Name of the ECR repository (created by this module).
ecr_repo_name = "myapp-stable"

# Image tag to deploy (single / fleet modes). Overridden by blue/green tags in asg-bluegreen.
ecr_image_tag = "latest"

# ─────────────────────────────────────────────
# S3
# ─────────────────────────────────────────────

# Must be globally unique across all AWS accounts.
s3_bucket_name = "myapp-stable-assets-UNIQUE_SUFFIX"

# ─────────────────────────────────────────────
# Secrets Manager
# ─────────────────────────────────────────────

# ARN of the secret containing the application's .env key-value pairs as a JSON object.
# The EC2 startup script will fetch this and write it to /app/.env at boot.
secrets_arn = "arn:aws:secretsmanager:ap-southeast-1:123456789012:secret:myapp-stable-env-XXXXXX"

# ─────────────────────────────────────────────
# RDS PostgreSQL
# ─────────────────────────────────────────────

# Moderate instance class for stable.
rds_instance_class = "db.t3.small"

# Initial storage in GiB.
rds_allocated_storage = 20

# Storage auto-scaling ceiling in GiB. Set to 0 to disable.
rds_max_allocated_storage = 100

# Multi-AZ disabled for stable — enable if you want to test failover behaviour.
rds_multi_az = false

# Name of the initial database.
rds_db_name = "myapp_stable"

# Master username.
rds_username = "myapp"

# Master password — use a strong randomly generated value.
rds_password = "REPLACE_WITH_STRONG_PASSWORD"

# Deletion protection enabled for stable to prevent accidental data loss.
rds_deletion_protection = true

# Days of automated backup retention.
rds_backup_retention_days = 7

# ─────────────────────────────────────────────
# ElastiCache Redis
# ─────────────────────────────────────────────

# Moderate node type for stable.
redis_node_type = "cache.t3.small"

# "single" = standalone cache node; "cluster" = sharded replication group.
redis_cluster_mode = "single"

# ─────────────────────────────────────────────
# ASG blue/green (only used when deployment_mode = "asg-bluegreen")
# ─────────────────────────────────────────────

# ECR image tags for each slot. The live slot receives all traffic (weight = 100).
blue_ecr_tag  = "latest"
green_ecr_tag = "latest"

# Weights must sum to 100.
# 100 / 0 = all traffic to blue (initial safe state).
blue_weight  = 100
green_weight = 0

# Minimum healthy targets required before a blue/green deploy is declared successful.
health_check_min_healthy = 1

# Seconds to wait for healthy targets before the health gate fails the apply.
health_check_timeout_seconds = 300
